#include <stdio.h>
#define SIZE 100  // Maximum size of the tree array

int tree[SIZE];
int lastUsedIndex = -1;

// Function to check if tree is full
int isFull() {
    return lastUsedIndex + 1 == SIZE;
}

// Function to insert a node
void insert(int value) {
    if (isFull()) {
        printf("Tree is full! Cannot insert %d.\n", value);
        return;
    }
    lastUsedIndex++;
    tree[lastUsedIndex] = value;
    printf("Inserted %d into the tree.\n", value);
}

// Function for level order traversal
void levelOrder() {
    if (lastUsedIndex == -1) {
        printf("Tree is empty.\n");
        return;
    }
    printf("Level order: ");
    for (int i = 0; i <= lastUsedIndex; i++) {
        printf("%d ", tree[i]);
    }
    printf("\n");
}

// Recursive Pre-order traversal
void preOrder(int index) {
    if (index > lastUsedIndex)
        return;
    printf("%d ", tree[index]);
    preOrder(2 * index + 1); // Left child
    preOrder(2 * index + 2); // Right child
}

// Recursive In-order traversal
void inOrder(int index) {
    if (index > lastUsedIndex)
        return;
    inOrder(2 * index + 1);
    printf("%d ", tree[index]);
    inOrder(2 * index + 2);
}

// Recursive Post-order traversal
void postOrder(int index) {
    if (index > lastUsedIndex)
        return;
    postOrder(2 * index + 1);
    postOrder(2 * index + 2);
    printf("%d ", tree[index]);
}

// Function to delete a node
void deleteNode(int value) {
    if (lastUsedIndex == -1) {
        printf("Tree is empty! Cannot delete %d.\n", value);
        return;
    }
    int i;
    for (i = 0; i <= lastUsedIndex; i++) {
        if (tree[i] == value) {
            tree[i] = tree[lastUsedIndex]; // Replace with last node
            lastUsedIndex--;
            printf("Deleted %d from the tree.\n", value);
            return;
        }
    }
    printf("Node %d not found in the tree.\n", value);
}

// Main menu
int main() {
    int choice, value;

    while (1) {
        printf("\n--- Binary Tree Operations ---\n");
        printf("1. Insert\n");
        printf("2. Delete\n");
        printf("3. Level Order Traversal\n");
        printf("4. Pre-order Traversal\n");
        printf("5. In-order Traversal\n");
        printf("6. Post-order Traversal\n");
        printf("0. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter value to insert: ");
                scanf("%d", &value);
                insert(value);
                break;
            case 2:
                printf("Enter value to delete: ");
                scanf("%d", &value);
                deleteNode(value);
                break;
            case 3:
                levelOrder();
                break;
            case 4:
                printf("Pre-order: ");
                preOrder(0);
                printf("\n");
                break;
            case 5:
                printf("In-order: ");
                inOrder(0);
                printf("\n");
                break;
            case 6:
                printf("Post-order: ");
                postOrder(0);
                printf("\n");
                break;
            case 0:
                printf("Exiting program. Goodbye!\n");
                return 0;
            default:
                printf("Invalid choice. Try again.\n");
        }
    }

    return 0;
}
