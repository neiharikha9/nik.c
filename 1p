#include <stdio.h>
#define MAX 100   

int tree[MAX];   
int size = 0;    

void insert(int value) {
    if (size == MAX) {
        printf("Tree is full!\n");
        return;
    }

    tree[size] = value;  
    size++;

    printf("Inserted %d into the tree.\n", value);
}
int find(int value) {
    for (int i = 0; i < size; i++) {
        if (tree[i] == value)
            return i;
    }
    return -1; 
}
void deleteValue(int value) {
    int index = find(value);

    if (index == -1) {
        printf("Value %d not found!\n", value);
        return;
    }
tree[index] = tree[size - 1];
    size--;

    printf("Deleted %d from the tree.\n", value);
}
void inorder(int index) {
    if (index >= size)
        return;

    inorder(2 * index + 1); 
    printf("%d ", tree[index]); 
    inorder(2 * index + 2);  
}
int main() {
    insert(10);
    insert(20);
    insert(30);
    insert(40);
    insert(50);
    printf("\nInorder traversal: ");
    inorder(0);
    printf("\n");
  
    deleteValue(20);

    printf("\nAfter deletion: ");
    inorder(0);
    printf("\n");
     insert(60);

    printf("\nAfter inserting 60: ");
    inorder(0);
    printf("\n");

    return 0;
}


