#include<stdio.h>
#define max 100
struct queue{
    int data;
    int priority;
};
struct queue pqueue[max];
int front = -1, rear = -1;
int isfull(){
    return front == rear;
}
int isempty(){
    return front  == -1;
}
void enqueue(int data, int priority){
    if(isfull){
        printf("Queue Overflow!!!\n");
        return ;
    }
    front++;
    pqueue[rear].data = data;
    pqueue[rear].priority = priority;
    if(front == -1){
        front = rear ;
        printf("Element inserted in priority queue!!!\n");
    }
}
int dequeue(){
    if(isempty()){
        printf("\nQueue Underflow!!\n");
        return -1;
    }
    int val = queue[front++];
    if(front == rear){
        front = rear = -1;
    }
    else if(front == max-1){
        front = 0;
    }
    else{
        front++;
        return val;
    }
}
int peek(){
    if(isempty()){
        printf("Queue Underflow!!\n");
        return -1;
    }
    return queue[front];
}
int display(){
    if(isempty()){
        printf("Queue is empty!!1\n");
        return 0;
    }
    for(int i=front ; i<=rear ; i++){
        printf("%d", queue[i]);
    }
    printf("\n");
}
int main(){
    int choice,value;
    while(1){
        printf("1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. Peek\n");
        printf("4. Display\n");
        printf("5. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice){
            case 1:
            printf("Enter Value: ");
            scanf("%d", &value);
            enqueue(value);
            break;
            case 2:
            value = dequeue();
            if(value != -1){
                printf("%d dequeue from the circular queue!!!\n",value);
            }
            break;
            case 3:
            peek();
            break;
            case 4:
            display();
            break;
            case 5:
            printf("Exit");
            return -1;
            break;
        }
    }
}